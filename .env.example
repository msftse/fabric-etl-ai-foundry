# ─── Azure Subscription ───
AZURE_SUBSCRIPTION_ID=<your-subscription-id>
AZURE_RESOURCE_GROUP=<your-resource-group>

# ─── Fabric Capacity ───
FABRIC_CAPACITY_NAME=etl-fabric-capacity
FABRIC_LOCATION=eastus
FABRIC_SKU=F2
FABRIC_ADMIN_EMAIL=admin@contoso.com

# ─── OneLake Storage ───
ONELAKE_ACCOUNT_NAME=onelake
ONELAKE_WORKSPACE_NAME=<your-workspace-name>
ONELAKE_LAKEHOUSE_NAME=<your-lakehouse-name>

# ─── Azure AI Foundry ───
AZURE_AI_PROJECT_ENDPOINT=https://<project>.services.ai.azure.com/api/projects/<project-id>
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4o-mini

# ─── Optional: Bing Web Search ───
BING_CONNECTION_ID=<your-bing-connection-id>
