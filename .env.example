# ─── Azure Subscription ───
AZURE_SUBSCRIPTION_ID=<your-subscription-id>
AZURE_RESOURCE_GROUP=<your-resource-group>

# ─── Fabric Capacity ───
FABRIC_CAPACITY_NAME=etl-fabric-capacity
FABRIC_LOCATION=eastus
FABRIC_SKU=F2
FABRIC_ADMIN_EMAIL=admin@contoso.com
FABRIC_WORKSPACE_ID=<your-workspace-id>
FABRIC_LAKEHOUSE_ID=<your-lakehouse-id>

# ─── OneLake Storage ───
ONELAKE_ACCOUNT_NAME=onelake
ONELAKE_WORKSPACE_NAME=<your-workspace-name>
ONELAKE_LAKEHOUSE_NAME=<your-lakehouse-name>

# ─── Snowflake (optional — for mirrored/direct ingestion) ───
SNOWFLAKE_ACCOUNT=<your-account>.snowflakecomputing.com
SNOWFLAKE_USER=<your-user>
SNOWFLAKE_PASSWORD=<your-password>
SNOWFLAKE_WAREHOUSE=<your-warehouse>
SNOWFLAKE_DATABASE=<your-database>
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_ROLE=<your-role>

# ─── Azure AI Foundry ───
AZURE_AI_PROJECT_ENDPOINT=https://<project>.services.ai.azure.com/api/projects/<project-id>
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4o

# ─── Fabric Data Agent Connection (Foundry IQ -> OneLake) ───
# Format: /subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.MachineLearningServices/workspaces/<project>/connections/<connection-name>
FABRIC_CONNECTION_ID=<your-fabric-connection-id>

# ─── Azure AI Search (Foundry IQ knowledge base for unstructured docs) ───
AI_SEARCH_CONNECTION_ID=<your-ai-search-connection-id>

# ─── Optional: Bing Web Search ───
BING_CONNECTION_ID=<your-bing-connection-id>

# ─── Confluence Cloud ───
CONFLUENCE_URL=https://<your-domain>.atlassian.net/wiki
CONFLUENCE_EMAIL=<your-email@example.com>
CONFLUENCE_API_TOKEN=<your-api-token>
